{
  "$schema": "https://turborepo.dev/schema.v2.json",
  "ui": "tui",
  "envMode": "strict",
  "globalEnv": [
    "AI_API_KEY",
    "AUTUMN_SECRET_KEY",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "CLICKHOUSE_URL",
    "DATABASE_URL",
    "DATABUDDY_API_KEY",
    "DATABUDDY_WEBSITE_ID",
    "GITHUB_CLIENT_ID",
    "GITHUB_CLIENT_SECRET",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "MARBLE_API_URL",
    "MARBLE_WORKSPACE_KEY",
    "NEXT_PUBLIC_API_URL",
    "NODE_ENV",
    "NOTRA_API_KEY",
    "OPR_API_KEY",
    "REDIS_URL",
    "REDPANDA_BROKER",
    "REDPANDA_PASSWORD",
    "REDPANDA_USER",
    "RESEND_API_KEY",
    "UPSTASH_QSTASH_TOKEN"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "start": {
      "dependsOn": ["^start"],
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:deploy": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "check-types": {},
    "clickhouse:init": {
      "cache": false,
      "persistent": false
    },
    "dev": {
      "dependsOn": ["@databuddy/sdk#build"],
      "cache": false,
      "persistent": true
    }
  }
}
